# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hr_hub

# Security (Required: MUST SET - Generate with: openssl rand -hex 32)
# SECRET_KEY must be a cryptographically strong string of at least 32 characters.
SECRET_KEY=

# Security (Required: MUST SET - Generate with: openssl rand -hex 32)
# HMAC_SECRET_KEY must be a cryptographically strong string of at least 32 characters.
HMAC_SECRET_KEY=

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Security Mode Flags (Required: MUST SET - Set to False in production)
ENABLE_MOCK_LOGIN=
DEV_MODE=

# Google OAuth (Required: Get credentials from GCP Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Sheets Integration (Phase 4)
# Path to a GCP service account JSON key file with Sheets API access.
# Leave blank to run in mock/fallback mode during development.
GOOGLE_SHEETS_CREDENTIALS=/path/to/service-account.json

# Fallback Google Sheet ID used when no per-user sheet mapping is configured.
# Get this from the Sheet URL: https://docs.google.com/spreadsheets/d/<SHEET_ID>/
FALLBACK_SHEET_ID=

# Google Drive Integration (Phase 5)
# Path to a GCP service account JSON key file with Drive API access.
# The service account must have the 'drive.file' scope.
# Leave blank to run in mock/fallback mode during development.
GOOGLE_DRIVE_CREDENTIALS=/path/to/drive-service-account.json

# Root Drive folder ID under which date-partitioned folders are created:
#   <root>/<YYYY>/<MM>/<YYYY-MM-DD>
# Get this from the folder URL: https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Google Chat Integration (Phase 7 / Phase 9)
# Option A — Paste an Incoming Webhook URL from a Google Chat space:
GOOGLE_CHAT_WEBHOOK_URL=
# Option B — Path to a GCP service account JSON key with Chat API access:
GOOGLE_CHAT_CREDENTIALS=
# Optional: shared secret for HMAC-SHA256 signature verification on the webhook endpoint:
GOOGLE_CHAT_WEBHOOK_SECRET=
# Google Chat space ID to receive emergency alerts (e.g. spaces/AAAAAAA)
GOOGLE_CHAT_HR_ROOM_ID=

# Google Calendar/Meet Integration (Phase 8)
# Path to a GCP service account JSON key file with Calendar API access.
# Leave blank to fallback to other Google credentials or mock mode.
GOOGLE_CALENDAR_CREDENTIALS=/path/to/calendar-service-account.json

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000"]