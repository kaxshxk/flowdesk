# ─────────────────────────────────────────────────────────────────────────────
# FlowDesk — HR-Productivity Hub
# Root environment template
# Copy to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/hr_hub

# ── JWT & Security ────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# HMAC signing key for task-log integrity verification
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
HMAC_SECRET_KEY=your-hmac-secret-key-here

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Google Sheets (task ledger) ───────────────────────────────────────────────
# Path to GCP service-account JSON with Sheets API access.
# Leave blank to run in mock/fallback mode.
GOOGLE_SHEETS_CREDENTIALS=/path/to/service-account.json
FALLBACK_SHEET_ID=your-google-sheet-id-here

# ── Google Drive (file vault) ─────────────────────────────────────────────────
# Path to GCP service-account JSON with Drive API (drive.file scope).
GOOGLE_DRIVE_CREDENTIALS=/path/to/drive-service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-drive-root-folder-id-here

# ── Google Chat (space relay) ─────────────────────────────────────────────────
# Option A — incoming webhook URL from a Google Chat space:
GOOGLE_CHAT_WEBHOOK_URL=
# Option B — service-account JSON with Chat API access:
GOOGLE_CHAT_CREDENTIALS=
GOOGLE_CHAT_WEBHOOK_SECRET=
GOOGLE_CHAT_HR_ROOM_ID=your-google-chat-hr-room-id-here

# ── Google Calendar / Meet ────────────────────────────────────────────────────
GOOGLE_CALENDAR_CREDENTIALS=/path/to/calendar-service-account.json

# ── CORS (comma-separated origins allowed to call the API) ────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
